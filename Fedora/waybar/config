{
    "margin-top": 5,
    "margin-left": 10,
    "margin-right": 10,
    "height": 30,
    "modules-left": [
        "hyprland/workspaces",
        "hyprland/window"
    ],
    "modules-center": [
        "clock",
        "mpd"
    ],
"modules-right": [
    "tray",
    "pulseaudio",
    "network",
    "temperature",
    "cpu",
    "memory",
    "custom/weather",
    "custom/notification"
],

    "mpd": {
        "server": "localhost",
        "port": 6600,
        "format-stopped": "",
        "dynamic-order": ["title", "artist"],
        "format": "{stateIcon} {artist} - {title} ",
        "on-click": "mpc toggle",
        "dynamic-len": 50,
        "state-icons": {
            "playing": "’Ćü ",
            "paused": "¾░Åż"
        }
    },

"clock": {
        "locale": "id_ID.UTF-8",
        "format": "{:%H:%M}",
        "format-alt": "{:%A, %d %B %Y}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><big>{calendar}</big></tt>"
    },

    "tray": {
        "icon-size": 15,
        "spacing": 10
    },

    "hyprland/window": {
        "format": "{}",
        "max-length": 35,
        "rewrite": {
            "": "Harsh"
        },
        "separate-outputs": true
    },

    "hyprland/workspaces": {
        "format": "{icon}",
        "on-click": "activate",
        "format-icons": {
            "active": "’äæ "
        },
        "sort-by-number": true,
        "persistent-workspaces": {
            "*": 4,
            "HDMI-A-1": 3
        }
    },

    "network": {
        "format-wifi": "’ć½  {signalStrength}%",
        "format-ethernet": "’ć½",
        "tooltip-format": "{ifname} via {gwaddr} ’×¢",
        "format-linked": "{ifname} (No IP) ’×¢",
        "format-disconnected": " ŌÜĀ ",
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },

    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-muted": "Ņ¼ż Muted",
        "format-icons": {
            "default": ["’Ć”", "’Ć¦", "’Ć©"]
        },
        "scroll-step": 5,
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-click-right": "pavucontrol"
    },

    "cpu": {
        "format": "’ŗø  {usage}%",
        "tooltip": true
    },

    "memory": {
        "format": "’āē  {}%"
    },

    "temperature": {
    "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
    "critical-threshold": 80,
    "format": "{icon} {temperatureC}┬░C",
    "format-icons": ["’ŗŗ", "’ŗē", "’ŗć"]
    },

    "custom/notification": {
        "tooltip": true,
        "format": "<span size='16pt'>{icon}</span>",
        "format-icons": {
            "notification": "¾▒ģ½",
            "none": "¾░é£",
            "dnd-notification": "¾░éĀ",
            "dnd-none": "¾░¬ō",
            "inhibited-notification": "¾░éø",
            "inhibited-none": "¾░¬æ",
            "dnd-inhibited-notification": "¾░éø",
            "dnd-inhibited-none": "¾░¬æ"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },
    "custom/weather": {
    "format": "{}",
    "tooltip": true,
    "interval": 3600, // Update setiap 3600 detik (1 jam)
    "exec": "~/.config/waybar/scripts/weather.sh",
    "return-type": "json"
    }
}

